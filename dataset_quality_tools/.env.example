# Multi-frame video captioning configuration
#
# Copy this file to .env and fill in your values.

# Required: API key for the OpenAI-compatible endpoint.
OPENAI_API_KEY=sk-your-key-here

# Optional: custom base URL for API relays such as DMX API.
# OPENAI_BASE_URL=https://www.dmxapi.cn/v1

# Optional: vision model to use.
NEXIS_CAPTION_MODEL=gpt-4o-mini

# Optional: number of evenly spaced keyframes to extract from each clip.
# 1 = caption only the first frame. 4 = caption first + 3 keyframes.
NEXIS_CAPTION_KEYFRAMES=4
